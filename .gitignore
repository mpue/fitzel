# Build output
/build/
/out/
cmake-build-*/

# CMake
CMakeCache.txt
CMakeFiles/
compile_commands.json

# IDE / editor
/.vs/
/.vscode/
/.idea/
*.user

# Large binary texture assets (provided locally, not tracked)
/content/textures/

# Model assets: only the default tree is tracked; other imported models
# (often carrying embedded 4k textures) stay local.
content/models/*.glb
content/models/*.gltf
content/models/*.bin
!content/models/tree1.glb
!content/models/tree1.gltf
!content/models/tree1.bin
# Imported asset packs (Unity FBX etc.) are copied into per-pack subfolders by
# the Unity importer; those stay local (large binaries + third-party content).
content/models/*/

# Audio assets (provided/generated locally, not tracked)
/content/sounds/

# Asset metadata sidecars are generated locally for now (Phase 1); the ignored
# content dirs above already exclude most of them.
*.meta

# Blender source/backup files (only the exported glTF is tracked)
*.blend
*.blend1

# OS
Thumbs.db
.DS_Store
